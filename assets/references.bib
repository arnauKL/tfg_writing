@article{houdaboulkrinatParkinsons2025,
  title = {Parkinson’s Disease Detection Based on {{3D Convolutional Neural Network}} and {{DaTscan}} Imaging},
  author = {Houda Boulkrinat, Nour El and Taourirt, Hamza and Saada, Samir},
  date = {2025-01-01},
  journaltitle = {Procedia Computer Science},
  shortjournal = {Procedia Computer Science},
  series = {16th {{International Conference}} on {{Emerging Ubiquitous Systems}} and {{Pervasive Networks}} / 15th {{International Conference}} on {{Current}} and {{Future Trends}} of {{Information}} and {{Communication Technologies}} in {{Healthcare}}},
  volume = {272},
  pages = {360--367},
  issn = {1877-0509},
  doi = {10.1016/j.procs.2025.10.216},
  url = {https://www.sciencedirect.com/science/article/pii/S187705092503563X},
  urldate = {2026-03-02},
  abstract = {The diagnosis and the detection of Parkinson’s disease remains a complex challenge, particularly in the early stages where symptoms are subtle. Traditional methods, although valuable, may have limitations in terms of accuracy and time efficiency. To address these challenges, this paper proposes deep learning-based detection model capable of automatically analyzing medical images to assist healthcare professionals in diagnosis. We proposed a 3D-CNN model using SPECT DaTscan images from the PPMI dataset. Following rigorous data preprocessing steps including background intensity removal, patch-wise denoising, and cropping centered on the striatum. Our model outperformed previously published studies and pretrained architectures such as 3D VGG, 3D ResNet, 3D DenseNet, S3D, and MedicalNet, achieving an accuracy of 99.53\%, with 99.50\% precision, 99.50\% recall, and a 99\% F1-score.},
